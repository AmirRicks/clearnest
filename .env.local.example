# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Server-only (never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# ----- Business -----
NEXT_PUBLIC_BUSINESS_PHONE=(801) 441-0726
NEXT_PUBLIC_YELP_URL=https://www.yelp.com/biz/clearnest-cleaning-services

# ----- Resend (Phase 2: email confirmations) -----
RESEND_API_KEY=
RESEND_FROM=ClearNest <hello@clearnest.services>
# The email address you want to RECEIVE lead notifications at
LEAD_NOTIFY_EMAIL=yourpersonal@email.com

# ----- Twilio (Phase 2: SMS) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
# The phone number you want to RECEIVE lead notifications at (E.164 format)
LEAD_NOTIFY_PHONE=

# ----- AI Receptionist -----
# OpenRouter API key (supports DeepSeek V4 Flash, Gemini, etc.)
# Get one at https://openrouter.ai/keys — free tier available
AI_API_KEY=

# ----- Stripe (Phase 2: invoiced payments) -----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
